---
// BaseLayout.astro — root layout for all pages
// Injects: fonts (Astro Fonts API), CSP, Cloudflare Analytics, Svelte hydration
import '../styles/global.css';
import TVIntro from '../components/TVIntro.svelte';
import Header from '../components/layout/Header.svelte';
import Footer from '../components/layout/Footer.svelte';
import { buildSeoMetadata } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title,
  description,
  ogImage: ogImageProp,
  noIndex = false,
} = Astro.props;

const site = Astro.site ?? new URL(Astro.url.origin);
const seo = buildSeoMetadata({
  site,
  pathname: Astro.url.pathname,
  title,
  description,
  ogImage: ogImageProp,
});
const cfAnalyticsToken = import.meta.env.CLOUDFLARE_ANALYTICS_TOKEN;
const shouldRenderTvIntro = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- SEO -->
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={seo.ogType} />
    <meta property="og:url" content={seo.canonicalUrl} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={seo.ogImageUrl} />
    <meta property="og:site_name" content={seo.ogSiteName} />

    <!-- Twitter -->
    <meta name="twitter:card" content={seo.twitterCard} />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.ogImageUrl} />
    <!-- Locale & author -->
    <meta property="og:locale" content="en_US" />
    <meta property="og:image:alt" content={seo.ogImageAlt} />
    <meta name="twitter:site" content="@jaysonknight" />
    <meta name="twitter:creator" content="@jaysonknight" />
    <meta name="twitter:image:alt" content={seo.ogImageAlt} />
    <meta name="author" content={seo.author} />
    <!-- Default robots for indexed pages -->
    {!noIndex && <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts — injected by Astro Fonts API (Space Grotesk, JetBrains Mono) -->
    <!-- The <Font> component injects optimized @font-face declarations automatically -->

    <!-- Theme color for browser chrome -->
    <meta name="theme-color" content="#05050a" />

    <!-- Shimmer preference — restore before first paint to prevent flash -->
    <script is:inline>
      (function() {
        try {
          const v = localStorage.getItem('shimmer-paused');
          if (v === 'true') document.documentElement.dataset.shimmerPaused = 'true';
        } catch (_) {}
      })();
    </script>

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="me" href="https://github.com/jaypatrick" />
    <link rel="me" href="https://www.linkedin.com/in/jaysonknight" />
    <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
    <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async></script>

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ProfessionalService',
      '@id': seo.canonicalUrl,
      name: 'JK.com — Jayson Knight Consulting',
      description: seo.description,
      url: seo.canonicalUrl,
      image: new URL('/apple-touch-icon.png', site).href,
      sameAs: [
        'https://github.com/jaypatrick',
        'https://www.linkedin.com/in/jaysonknight',
        'https://calendly.com/jaysonknight',
      ],
      telephone: '+19807297877',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Charlotte',
        addressRegion: 'NC',
        addressCountry: 'US',
      },
      founder: {
        '@type': 'Person',
        '@id': new URL('/#founder', site).href,
        name: 'Jayson Knight',
        jobTitle: 'Solutions Architect',
        url: 'https://jaysonknight.com',
        sameAs: ['https://github.com/jaypatrick', 'https://www.linkedin.com/in/jaysonknight'],
        knowsAbout: ['Microsoft Azure', 'Cloudflare', '.NET', 'Enterprise Software'],
      },
    })} />
  </head>

  <body class="grid-overlay">
    {shouldRenderTvIntro && <TVIntro client:load />}

    <!-- Subtle scan-line overlay (CSS only) -->
    <div
      class="pointer-events-none fixed inset-0 z-50 opacity-[0.015]"
      style="background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,212,255,0.5) 2px, rgba(0,212,255,0.5) 4px);"
      aria-hidden="true"
    ></div>

    <Header client:load />

    <main id="main-content">
      <slot />
    </main>

    <Footer client:idle />

    <!-- Cloudflare Web Analytics -->
    {cfAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}
      ></script>
    )}

    <!-- Intersection Observer for scroll animations -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );

      document.querySelectorAll('.animate-on-scroll').forEach((el) => {
        observer.observe(el);
      });
    </script>

    <!-- Shimmer viewport observer — pause ::after on off-screen tiles to save GPU -->
    <script>
      (function () {
        const shimmerObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('shimmer-in-view');
              } else {
                entry.target.classList.remove('shimmer-in-view');
              }
            });
          },
          { threshold: 0, rootMargin: '0px' }
        );

        function observeShimmerEl(el) {
          if (el.hasAttribute('data-shimmer-observed')) return;
          el.setAttribute('data-shimmer-observed', '1');
          shimmerObserver.observe(el);
        }

        function observeShimmerRoot(root) {
          if (!(root instanceof Element) && !(root instanceof Document)) return;

          if (root instanceof Element && root.matches('.iridescent')) {
            observeShimmerEl(root);
          }

          root.querySelectorAll('.iridescent:not([data-shimmer-observed])').forEach((el) => {
            observeShimmerEl(el);
          });
        }

        const pendingNodes = new Set();
        let scheduled = false;

        function flushPendingShimmerNodes() {
          scheduled = false;
          pendingNodes.forEach((node) => {
            observeShimmerRoot(node);
          });
          pendingNodes.clear();
        }

        function scheduleObserveAddedNodes(mutationList) {
          mutationList.forEach((mutation) => {
            mutation.addedNodes.forEach((node) => {
              if (node.nodeType === Node.ELEMENT_NODE) {
                pendingNodes.add(node);
              }
            });
          });

          if (!scheduled && pendingNodes.size > 0) {
            scheduled = true;
            requestAnimationFrame(flushPendingShimmerNodes);
          }
        }

        observeShimmerRoot(document);

        // Catch dynamically-added tiles (e.g. RssFeed mounts async)
        const mutationObs = new MutationObserver(scheduleObserveAddedNodes);
        mutationObs.observe(document.body, { childList: true, subtree: true });
      })();
    </script>
  </body>
</html>
